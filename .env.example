# Copy this file to .env and edit the values as needed.
# The application loads .env automatically via python-dotenv.

# Flask bind address. Use 0.0.0.0 when running inside Docker or a cloud VM.
HOST=127.0.0.1

# Flask port.
PORT=5000

# Set to 1 to enable Flask debug mode (development only, never in production).
FLASK_DEBUG=0
